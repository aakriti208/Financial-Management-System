digraph {
	bgcolor=white compound=true dpi=200 fontname=Helvetica fontsize=18 label="Statechart S5 — AI Financial Advisor Session\nSRS §3.1.7 AI Financial Advisor" labeljust=c labelloc=t newrank=true nodesep=0.55 pad=0.4 rankdir=TB ranksep=0.9 size="16,11!" splines=spline
	node [fontname=Helvetica fontsize=12]
	edge [arrowsize=0.9 fontname=Helvetica fontsize=10 penwidth=1.2]
	s5_start [label="" color=black fillcolor=black fixedsize=true height=0.28 shape=circle style=filled width=0.28]
	s5_idle [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Idle</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">entry / navigate to AIAdvisorPage</FONT></TD></TR></TABLE>> color="#455A64" fillcolor="#ECEFF1" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_compose [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Composing Question</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">entry / focus AIChat textarea</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / user types question</FONT></TD></TR></TABLE>> color="#E65100" fillcolor="#FFF3E0" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_sending [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Sending Request</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / POST /api/ai/ask</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  @Valid AIQueryDTO { question }</FONT></TD></TR></TABLE>> color="#F9A825" fillcolor="#FFFDE7" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_context [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Loading Context</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / AIAdvisorService.ask(email, query)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  fetch DashboardSummaryDTO</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  fetch recent expenses + income</FONT></TD></TR></TABLE>> color="#1565C0" fillcolor="#E3F2FD" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_prompt [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Building Prompt</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / assemble system prompt</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  {totals, recent items,</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">   user question}</FONT></TD></TR></TABLE>> color="#1565C0" fillcolor="#E3F2FD" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_await [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Awaiting OpenAI</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / POST api.openai.com/v1/chat/completions</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  Authorization: Bearer ${openai.api.key}</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  model: gpt-4o-mini</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  (≤ 5 s SLA per NFR)</FONT></TD></TR></TABLE>> color="#6A1B9A" fillcolor="#F3E5F5" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_stream [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Streaming Response</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / read completion chunks</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  append to AIChat message</FONT></TD></TR></TABLE>> color="#6A1B9A" fillcolor="#F3E5F5" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_shown [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Response Displayed</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">entry / render AIResponseDTO</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">  answer, model, generatedAt</FONT></TD></TR></TABLE>> color="#2E7D32" fillcolor="#E8F5E9" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_error [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>Error</B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">entry / show error banner</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">do / log + offer retry</FONT></TD></TR></TABLE>> color="#C62828" fillcolor="#FFEBEE" penwidth=1.6 shape=rectangle style="rounded,filled"]
	s5_end [label="" color=black fillcolor=black fixedsize=true height=0.32 penwidth=1.4 shape=doublecircle style=filled width=0.32]
	s5_start -> s5_idle [label="" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_idle -> s5_compose [label="open chat" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_compose -> s5_sending [label="click Send" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_sending -> s5_context [label="201 Accepted" arrowhead=vee color="#2E7D32" fontcolor="#2E7D32" style=solid]
	s5_sending -> s5_error [label="400 Bad Request [empty question]" arrowhead=vee color="#C62828" fontcolor="#C62828" style=dashed]
	s5_context -> s5_prompt [label="context loaded" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_prompt -> s5_await [label="HTTP call dispatched" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_await -> s5_stream [label="200 OK" arrowhead=vee color="#2E7D32" fontcolor="#2E7D32" style=solid]
	s5_await -> s5_error [label="timeout / 5xx [elapsed > 5 s]" arrowhead=vee color="#C62828" fontcolor="#C62828" style=dashed]
	s5_stream -> s5_shown [label="stream complete" arrowhead=vee color="#2E7D32" fontcolor="#2E7D32" style=solid]
	s5_shown -> s5_compose [label="follow-up question" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_error -> s5_compose [label="click Retry" arrowhead=vee color="#37474F" fontcolor="#37474F" style=solid]
	s5_shown -> s5_end [label="close chat" arrowhead=vee color="#455A64" fontcolor="#455A64" style=solid]
}
